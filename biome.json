{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": "off",
        "useIterableCallbackReturn": "warn"
      },
      "complexity": {
        "noForEach": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      },
      "style": {
        "noParameterAssign": "off",
        "useConst": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "site/**",
      "functions/**",
      "tests/**",
      "marketing/**/*.js",
      "deploy.js",
      "vitest.config.js",
      "package.json",
      "biome.json"
    ]
  }
}
