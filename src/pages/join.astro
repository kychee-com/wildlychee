---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Join">
  <div class="container" style="max-width:28rem;margin:4rem auto">
    <div class="card" id="join-card">
      <h2 id="join-title">Sign In</h2>
      <div id="join-error" class="text-sm hidden" style="color:var(--color-danger);margin-bottom:1rem"></div>

      <button class="btn-google" id="join-google-btn">
        <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.997 8.997 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/></svg>
        Sign in with Google
      </button>

      <div class="auth-divider">or</div>

      <form id="join-form">
        <div class="form-group">
          <label class="form-label" for="join-email">Email</label>
          <input class="form-input" type="email" id="join-email" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="join-password">Password</label>
          <input class="form-input" type="password" id="join-password" required minlength="6">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%" id="join-submit">Sign In</button>
      </form>

      <p class="text-sm text-muted mt-2 text-center">
        <a href="#" id="join-toggle">Don't have an account? Sign up</a>
      </p>
    </div>
  </div>
</Portal>

<script>
  import { signInWithGoogle, signIn, signUp, isAuthenticated } from '../lib/auth';

  if (isAuthenticated()) {
    window.location.href = '/';
  }

  let isSignUpMode = false;

  document.getElementById('join-google-btn')?.addEventListener('click', () => signInWithGoogle());

  document.getElementById('join-toggle')?.addEventListener('click', (e) => {
    e.preventDefault();
    isSignUpMode = !isSignUpMode;
    const title = document.getElementById('join-title');
    const toggle = document.getElementById('join-toggle');
    const submit = document.getElementById('join-submit');
    if (title) title.textContent = isSignUpMode ? 'Sign Up' : 'Sign In';
    if (toggle) toggle.textContent = isSignUpMode ? 'Already have an account? Sign in' : "Don't have an account? Sign up";
    if (submit) submit.textContent = isSignUpMode ? 'Sign Up' : 'Sign In';
  });

  document.getElementById('join-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('join-email') as HTMLInputElement).value;
    const password = (document.getElementById('join-password') as HTMLInputElement).value;
    const errEl = document.getElementById('join-error');
    try {
      if (isSignUpMode) {
        await signUp(email, password);
        if (errEl) {
          errEl.textContent = 'Account created! Check your email to verify.';
          errEl.style.color = 'var(--color-success)';
          errEl.classList.remove('hidden');
        }
      } else {
        await signIn(email, password);
        window.location.href = '/';
      }
    } catch (err: any) {
      if (errEl) {
        errEl.textContent = err.message || 'Authentication failed';
        errEl.style.color = 'var(--color-danger)';
        errEl.classList.remove('hidden');
      }
    }
  });
</script>
