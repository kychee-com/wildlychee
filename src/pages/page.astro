---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Page">
  <div class="container">
    <h1 id="page-title"></h1>
    <div id="page-content" class="mt-2"></div>
    <div id="page-sections" class="mt-2"></div>
  </div>
</Portal>

<script>
  import { get } from '../lib/api';
  import { isAdmin, isAuthenticated } from '../lib/auth';
  import { translateItems } from '../lib/config';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  async function initPage() {
    // Guard: astro:after-swap fires initPage on EVERY navigation, including routes
    // that don't own these elements. Bail out cleanly if we're not on /page.html.
    const titleEl = document.getElementById('page-title');
    const contentEl = document.getElementById('page-content');
    const sectionsContainer = document.getElementById('page-sections');
    if (!titleEl || !contentEl || !sectionsContainer) return;

    titleEl.textContent = '';
    contentEl.innerHTML = '';
    sectionsContainer.innerHTML = '';

    const slug = new URLSearchParams(window.location.search).get('slug');
    if (!slug) {
      titleEl.textContent = 'Page not found';
      return;
    }

    try {
      const pages = await get(`pages?slug=eq.${slug}&published=eq.true&limit=1`);
      if (pages.length === 0) {
        titleEl.textContent = 'Page not found';
        return;
      }

      const page = pages[0];
      await translateItems('page', [page], ['title', 'content']);

      // Auth gate
      if (page.requires_auth && !isAuthenticated()) {
        const { navigate } = await import('astro:transitions/client');
        navigate('/');
        return;
      }

      document.title = page.title;
      titleEl.textContent = page.title;
      if (isAdmin()) {
        titleEl.setAttribute('data-editable', `pages.${page.id}.title`);
      }
      if (page.content) {
        contentEl.innerHTML = page.content;
        if (isAdmin()) {
          contentEl.setAttribute('data-editable-rich', `pages.${page.id}.content`);
        }
      }

      // Load sections
      const sections = await get(`sections?page_slug=eq.${slug}&visible=eq.true&order=position.asc`);
      for (const s of sections) {
        const el = document.createElement('div');
        el.className = 'section section-visible';
        if (s.config?.html) {
          el.innerHTML = s.config.html;
        } else if (s.section_type === 'faq') {
          el.innerHTML = (s.config.items || []).map((f: any) =>
            `<details class="card mb-1"><summary style="font-weight:600;cursor:pointer">${esc(f.q)}</summary><p class="text-muted mt-1">${esc(f.a)}</p></details>`
          ).join('');
        }
        sectionsContainer.appendChild(el);
      }
    } catch (_e) {
      titleEl.textContent = 'Error loading page';
    }
  }

  initPage();
  document.addEventListener('astro:after-swap', initPage);
  document.addEventListener('wl-locale-changed', initPage);
  document.addEventListener('wl-auth-changed', initPage);
</script>
