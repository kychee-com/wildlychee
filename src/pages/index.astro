---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Home">
  <div id="sections" data-sortable-group="homepage-sections">
    <div class="section section-visible" id="sections-skeleton" style="padding:2rem 0">
      <div class="container"><div class="skeleton skeleton-card mb-1"></div><div class="skeleton skeleton-card mb-1"></div></div>
    </div>
  </div>

  <div class="container">
    <section class="section section-visible" id="announcements-section">
      <h2 id="announcements-title">Announcements</h2>
      <div id="announcement-create" class="hidden mb-2"></div>
      <div id="announcements-feed">
        <div class="card mb-1"><div class="skeleton skeleton-heading"></div><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text"></div></div>
        <div class="card mb-1"><div class="skeleton skeleton-heading"></div><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text"></div></div>
      </div>
    </section>
  </div>
</Portal>

<script>
  import { del, get, patch, post } from '../lib/api';
  import { getSession, isAdmin } from '../lib/auth';
  import { isFeatureEnabled, getTranslatedContent, translateItems, cacheHeroImage, preloadHeroImage } from '../lib/config';
  import { getLocale } from '../lib/i18n';
  import { bindPollVoteListeners, createPollForm, submitPoll, fetchAttachedPoll, fetchAndRenderPoll } from '../lib/poll-ui';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function timeAgo(iso: string): string {
    const seconds = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    if (days < 30) return `${days}d ago`;
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }

  function featureIcon(name: string): string {
    const icons: Record<string, string> = {
      users: '\u{1F465}', calendar: '\u{1F4C5}', 'book-open': '\u{1F4D6}', 'message-circle': '\u{1F4AC}',
      home: '\u{1F3E0}', settings: '\u2699\uFE0F', 'bar-chart-2': '\u{1F4CA}', shield: '\u{1F6E1}',
    };
    return icons[name] || '\u2726';
  }

  // --- Sections ---
  async function renderSections() {
    const container = document.getElementById('sections');
    if (!container) return;
    try {
      const sections = await get('sections?page_slug=eq.index&visible=eq.true&order=position.asc');
      container.style.minHeight = container.offsetHeight + 'px';
      document.getElementById('sections-skeleton')?.remove();
      const rendered = await Promise.all(sections.map((s: any) => renderSection(s)));
      for (const el of rendered) {
        container.appendChild(el);
      }
      // Admin: add section button
      if (isAdmin()) {
        const addBtn = document.createElement('div');
        addBtn.className = 'text-center';
        addBtn.style.padding = '1.5rem 0';
        addBtn.innerHTML = '<button class="btn btn-secondary" id="add-section-btn">+ Add Section</button>';
        container.appendChild(addBtn);
        document.getElementById('add-section-btn')?.addEventListener('click', openAddSectionPicker);
      }
      container.style.minHeight = '';
    } catch (e) {
      console.warn('Failed to load sections:', e);
      document.getElementById('sections-skeleton')?.remove();
      container.style.minHeight = '';
    }
  }

  async function renderSection(section: any): Promise<HTMLElement> {
    const cfg = section.config;
    const sid = section.id;
    const cfgJson = JSON.stringify(cfg).replace(/'/g, '&#39;');
    const el = document.createElement('section');
    // Sortable + config attributes for admin editing
    el.setAttribute('data-sortable-id', `sections.${sid}`);
    el.setAttribute('data-sortable-field', 'position');
    el.setAttribute('data-editable-config', JSON.stringify(cfg));

    const admin = isAdmin();

    // Admin: section remove button
    if (admin) {
      el.style.position = 'relative';
      const actions = document.createElement('div');
      actions.className = 'admin-section-actions';
      actions.innerHTML = `<button class="admin-section-btn danger" title="Remove section">&times;</button>`;
      actions.querySelector('.danger')!.addEventListener('click', async () => {
        if (!confirm('Remove this section?')) return;
        try {
          await del(`sections?id=eq.${sid}`);
          el.remove();
        } catch (e) { console.error('Failed to remove section:', e); }
      });
      el.appendChild(actions);
    }

    switch (section.section_type) {
      case 'hero':
        el.className = 'section section-hero';
        el.innerHTML = `<div class="container"${admin ? ` data-editable-image="sections.${sid}.config.bg_image" style="position:relative"` : ''}><h1${admin ? ` data-editable="sections.${sid}.config.heading"` : ''}>${esc(cfg.heading || '')}</h1><p${admin ? ` data-editable="sections.${sid}.config.subheading"` : ''}>${esc(cfg.subheading || '')}</p>${cfg.cta_text ? `<a href="${esc(cfg.cta_href || '#')}" class="btn btn-primary btn-lg"${admin ? ` data-editable="sections.${sid}.config.cta_text"` : ''}>${esc(cfg.cta_text)}</a>` : ''}</div>`;
        if (cfg.bg_image) { el.style.backgroundImage = `url(${cfg.bg_image})`; cacheHeroImage(cfg.bg_image); }
        break;

      case 'features': {
        el.className = 'section section-features';
        const cols = cfg.columns || 3;
        el.innerHTML = `<div class="container"><div class="features-grid" style="--cols:${cols}">${(cfg.items || []).map((item: any, i: number) => `<div class="feature-card"><div class="feature-icon">${featureIcon(item.icon)}</div><h3${admin ? ` data-editable="sections.${sid}.config.items.${i}.title"` : ''}>${esc(item.title || '')}</h3><p${admin ? ` data-editable="sections.${sid}.config.items.${i}.desc"` : ''}>${esc(item.desc || '')}</p></div>`).join('')}</div></div>`;
        break;
      }

      case 'cta':
        el.className = 'section section-cta';
        el.innerHTML = `<div class="container"><h2${admin ? ` data-editable="sections.${sid}.config.heading"` : ''}>${esc(cfg.heading || '')}</h2><p class="text-muted mt-1"${admin ? ` data-editable="sections.${sid}.config.text"` : ''}>${esc(cfg.text || '')}</p>${cfg.cta_text ? `<a href="${esc(cfg.cta_href || '#')}" class="btn btn-primary btn-lg mt-2"${admin ? ` data-editable="sections.${sid}.config.cta_text"` : ''}>${esc(cfg.cta_text)}</a>` : ''}</div>`;
        break;

      case 'stats':
        el.className = 'section section-stats';
        el.innerHTML = `<div class="container"><div class="stats-grid">${(cfg.items || []).map((s: any, i: number) => { const inner = `<div class="stat-value"${admin ? ` data-editable="sections.${sid}.config.items.${i}.value"` : ''}>${esc(s.value || '')}</div><div class="stat-label"${admin ? ` data-editable="sections.${sid}.config.items.${i}.label"` : ''}>${esc(s.label || '')}</div>`; return s.href ? `<a href="${esc(s.href)}" class="stat-card" style="text-decoration:none;color:inherit">${inner}</a>` : `<div class="stat-card">${inner}</div>`; }).join('')}</div></div>`;
        break;

      case 'testimonials':
        el.className = 'section';
        el.innerHTML = `<div class="container"><div class="card-grid">${(cfg.items || []).map((t: any, i: number) => `<div class="card"><p style="font-style:italic"${admin ? ` data-editable="sections.${sid}.config.items.${i}.quote"` : ''}>"${esc(t.quote || '')}"</p><p class="text-sm text-muted mt-1"${admin ? ` data-editable="sections.${sid}.config.items.${i}.name"` : ''}>- ${esc(t.name || '')}${t.role ? `, ${esc(t.role)}` : ''}</p></div>`).join('')}</div></div>`;
        break;

      case 'faq':
        el.className = 'section';
        el.innerHTML = `<div class="container"><h2 class="mb-2">FAQ</h2>${(cfg.items || []).map((f: any, i: number) => `<details class="card mb-1" style="cursor:pointer"><summary style="font-weight:600"${admin ? ` data-editable="sections.${sid}.config.items.${i}.q"` : ''}>${esc(f.q || '')}</summary><p class="text-muted mt-1"${admin ? ` data-editable="sections.${sid}.config.items.${i}.a"` : ''}>${esc(f.a || '')}</p></details>`).join('')}</div>`;
        break;

      case 'polls': {
        if (!isFeatureEnabled('feature_polls')) break;
        el.className = 'section section-polls';
        const pollIds: number[] = cfg.poll_ids || [];
        const session = getSession();
        const memberId = session?.user?.member?.id ?? null;
        const pollResults = new Map<number, any>();
        let pollsHtml = '';
        for (const pid of pollIds) {
          try {
            const result = await fetchAndRenderPoll(pid, session);
            pollResults.set(pid, result);
            pollsHtml += `<div class="card mb-1" data-section-poll="${pid}">${result.html}</div>`;
          } catch (e) {
            console.warn(`Failed to fetch poll ${pid}:`, e);
          }
        }
        el.innerHTML = `<div class="container">${cfg.heading ? `<h2 class="mb-2">${esc(cfg.heading)}</h2>` : ''}${pollsHtml || '<p class="text-muted">No polls to display.</p>'}</div>`;
        // Bind vote listeners using already-fetched data
        requestAnimationFrame(() => {
          for (const pid of pollIds) {
            const container = el.querySelector(`[data-section-poll="${pid}"]`) as HTMLElement;
            const result = pollResults.get(pid);
            if (!container || !result) continue;
            bindPollVoteListeners(container, result.poll, result.votes, memberId, () => renderSections());
          }
        });
        break;
      }

      default:
        el.className = 'section';
        if (cfg.html) el.innerHTML = `<div class="container">${cfg.html}</div>`;
        break;
    }
    return el;
  }

  // --- Admin: add section picker ---
  const SECTION_TEMPLATES: Record<string, { label: string; icon: string; config: any }> = {
    hero: { label: 'Hero Banner', icon: '\u{1F3DE}', config: { heading: 'New Hero', subheading: 'Add your subheading here', bg_image: '', cta_text: '', cta_href: '' } },
    stats: { label: 'Stats', icon: '\u{1F4CA}', config: { items: [{ value: '0', label: 'Stat 1' }, { value: '0', label: 'Stat 2' }, { value: '0', label: 'Stat 3' }] } },
    features: { label: 'Features', icon: '\u2728', config: { columns: 3, items: [{ icon: 'home', title: 'Feature 1', desc: 'Description' }] } },
    cta: { label: 'Call to Action', icon: '\u{1F4E2}', config: { heading: 'Ready to join?', text: 'Get started today.', cta_text: 'Join Now', cta_href: '/join.html' } },
    testimonials: { label: 'Testimonials', icon: '\u{1F4AC}', config: { items: [{ quote: 'Great community!', name: 'Member', role: '' }] } },
    faq: { label: 'FAQ', icon: '\u2753', config: { items: [{ q: 'Question?', a: 'Answer here.' }] } },
  };

  async function openAddSectionPicker() {
    document.querySelector('.admin-popover-backdrop')?.remove();
    document.querySelector('.admin-popover')?.remove();

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';

    const popover = document.createElement('div');
    popover.className = 'admin-popover';
    popover.innerHTML = `
      <h3>Add Section</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
        ${Object.entries(SECTION_TEMPLATES).map(([type, t]) =>
          `<button class="card" style="cursor:pointer;text-align:center;padding:1rem" data-section-type="${type}">
            <div style="font-size:1.5rem;margin-bottom:0.25rem">${t.icon}</div>
            <div style="font-weight:600">${t.label}</div>
          </button>`
        ).join('')}
      </div>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(popover);

    popover.querySelectorAll('[data-section-type]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const type = (btn as HTMLElement).dataset.sectionType!;
        const template = SECTION_TEMPLATES[type];
        try {
          const existingSections = document.querySelectorAll('[data-sortable-id]');
          await post('sections', {
            page_slug: 'index',
            section_type: type,
            config: template.config,
            position: existingSections.length + 1,
            visible: true,
          });
          close();
          await renderSections();
        } catch (e) { console.error('Failed to add section:', e); }
      });
    });

    backdrop.addEventListener('click', close);
    function close() { popover.remove(); backdrop.remove(); }
  }

  // --- Activity feed ---
  async function loadActivityFeed(limit: number) {
    const feed = document.getElementById('activity-feed');
    if (!feed) return;
    try {
      const entries = await get(`activity_log?order=created_at.desc&limit=${limit}`);
      if (entries.length === 0) { feed.innerHTML = '<p class="text-muted">No recent activity yet.</p>'; return; }
      const memberIds = [...new Set(entries.map((e: any) => e.member_id).filter(Boolean))];
      const membersMap: Record<number, any> = {};
      if (memberIds.length > 0) {
        const members = await get(`members?id=in.(${memberIds.join(',')})`);
        for (const m of members) membersMap[m.id] = m;
      }
      feed.innerHTML = entries.map((e: any) => {
        const member = membersMap[e.member_id];
        const name = member ? member.display_name : 'Former member';
        const avatar = member?.avatar_url
          ? `<img class="activity-avatar" src="${member.avatar_url}" alt="">`
          : `<div class="activity-avatar activity-avatar-fallback">${(name[0] || '?').toUpperCase()}</div>`;
        return `<div class="activity-entry">${avatar}<div class="activity-entry-content"><div class="activity-entry-text"><strong>${esc(name)}</strong> was active</div><div class="activity-entry-time">${timeAgo(e.created_at)}</div></div></div>`;
      }).join('');
    } catch { feed.innerHTML = '<p class="text-muted">Could not load activity.</p>'; }
  }

  // --- Announcements ---
  async function renderAnnouncements() {
    const feed = document.getElementById('announcements-feed');
    if (!feed) return;
    try {
      const items = await get('announcements?order=is_pinned.desc,created_at.desc&limit=20');
      await translateItems('announcement', items, ['title', 'body']);
      if (items.length === 0) { feed.innerHTML = '<p class="text-muted">No announcements yet.</p>'; return; }
      feed.style.minHeight = feed.offsetHeight + 'px';
      const session = getSession();
      const memberId = session?.user?.member?.id ?? null;
      const pollsEnabled = isFeatureEnabled('feature_polls');

      // Fetch attached polls for all announcements
      const attachedPolls: Record<number, any> = {};
      if (pollsEnabled) {
        for (const a of items) {
          try {
            const result = await fetchAttachedPoll('announcement', a.id, session);
            if (result) attachedPolls[a.id] = result;
          } catch (e) { console.warn(`Failed to fetch poll for announcement ${a.id}:`, e); }
        }
      }

      feed.innerHTML = items.map((a: any) => {
        const pollHtml = attachedPolls[a.id] ? `<div data-ann-poll="${a.id}">${attachedPolls[a.id].html}</div>` : '';
        return `
        <div class="announcement card mb-1 ${a.is_pinned ? 'pinned' : ''}" data-id="${a.id}">
          <div class="announcement-title" data-editable="announcements.${a.id}.title">${esc(a.title)}</div>
          <div class="announcement-body" data-editable-rich="announcements.${a.id}.body">${a.body}</div>
          ${pollHtml}
          <div class="announcement-meta">${a.is_pinned ? '<span class="badge badge-primary">Pinned</span> ' : ''}<span>${formatDate(a.created_at)}</span></div>
          ${isAdmin() ? `<div class="mt-1 flex gap-1"><button class="btn btn-sm btn-secondary ann-pin" data-id="${a.id}" data-pinned="${a.is_pinned}">${a.is_pinned ? 'Unpin' : 'Pin'}</button><button class="btn btn-sm btn-danger ann-delete" data-id="${a.id}">Delete</button></div>` : ''}
        </div>`;
      }).join('');

      // Bind poll vote listeners
      for (const [annId, pollData] of Object.entries(attachedPolls)) {
        const container = feed.querySelector(`[data-ann-poll="${annId}"]`) as HTMLElement;
        if (container) {
          bindPollVoteListeners(container, (pollData as any).poll, (pollData as any).votes, memberId, () => renderAnnouncements());
        }
      }

      feed.querySelectorAll('.ann-pin').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const el = btn as HTMLElement;
          await patch(`announcements?id=eq.${el.dataset.id}`, { is_pinned: el.dataset.pinned !== 'true' });
          renderAnnouncements();
        });
      });
      feed.querySelectorAll('.ann-delete').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const annId = (btn as HTMLElement).dataset.id!;
          // Delete attached poll if any
          try { await del(`polls?attached_to=eq.announcement&attached_id=eq.${annId}`); } catch (e) { console.warn('Failed to delete attached poll:', e); }
          await del(`announcements?id=eq.${annId}`);
          renderAnnouncements();
        });
      });
      feed.style.minHeight = '';
    } catch { feed.innerHTML = '<p class="text-muted">Could not load announcements.</p>'; }
  }

  // --- Admin: announcement creation ---
  let annPollFormRef: ReturnType<typeof createPollForm> | null = null;

  function setupAnnouncementCreate() {
    if (!isAdmin()) return;
    const container = document.getElementById('announcement-create');
    if (!container) return;
    container.classList.remove('hidden');
    const pollsEnabled = isFeatureEnabled('feature_polls');
    container.innerHTML = `<div class="card"><h4 class="mb-1">New Announcement</h4><div class="form-group"><input class="form-input" id="ann-title" placeholder="Title"></div><div class="form-group"><textarea class="form-textarea" id="ann-body" placeholder="Write your announcement..."></textarea></div>${pollsEnabled ? '<div id="ann-poll-form-container"></div><button class="btn btn-sm btn-secondary mb-1" id="ann-add-poll" type="button">+ Add Poll</button>' : ''}<button class="btn btn-primary" id="ann-post">Post</button></div>`;

    // Add poll button
    if (pollsEnabled) {
      document.getElementById('ann-add-poll')?.addEventListener('click', () => {
        const formContainer = document.getElementById('ann-poll-form-container')!;
        if (annPollFormRef) return; // already open
        annPollFormRef = createPollForm(formContainer);
        document.getElementById('ann-add-poll')!.classList.add('hidden');
        // Watch for form removal (user clicks X)
        const observer = new MutationObserver(() => {
          if (formContainer.innerHTML === '') {
            annPollFormRef = null;
            document.getElementById('ann-add-poll')?.classList.remove('hidden');
            observer.disconnect();
          }
        });
        observer.observe(formContainer, { childList: true });
      });
    }

    document.getElementById('ann-post')?.addEventListener('click', async () => {
      const title = (document.getElementById('ann-title') as HTMLInputElement).value.trim();
      const body = (document.getElementById('ann-body') as HTMLTextAreaElement).value.trim();
      if (!title || !body) return;
      const session = getSession();
      const memberId = session?.user?.member?.id;
      if (!memberId) return;

      const [created] = await post('announcements', { title, body, author_id: memberId });

      // Create attached poll if form is filled
      if (annPollFormRef) {
        const pollData = annPollFormRef.getPollData();
        if (pollData) {
          try {
            await submitPoll(pollData, memberId, { type: 'announcement', id: created.id });
          } catch (e) {
            console.error('Failed to create attached poll:', e);
          }
        }
        annPollFormRef = null;
      }

      (document.getElementById('ann-title') as HTMLInputElement).value = '';
      (document.getElementById('ann-body') as HTMLTextAreaElement).value = '';
      const formContainer = document.getElementById('ann-poll-form-container');
      if (formContainer) formContainer.innerHTML = '';
      document.getElementById('ann-add-poll')?.classList.remove('hidden');
      renderAnnouncements();
    });
  }

  // --- Boot ---
  async function bootHomepage() {
    // Kick off hero image preload before the sections API round-trip completes.
    // Only index.astro does this (per-page), since it's the only route that
    // renders a hero section — prevents "preloaded but not used" warnings on
    // resources/directory/etc.
    preloadHeroImage();
    await Promise.all([renderSections(), renderAnnouncements(), loadActivityFeed(15)]);
    setupAnnouncementCreate();
  }

  bootHomepage();
  document.addEventListener('astro:after-swap', bootHomepage);
  document.addEventListener('wl-locale-changed', bootHomepage);
  document.addEventListener('wl-auth-changed', bootHomepage);
</script>
