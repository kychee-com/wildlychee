---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Resources">
  <div class="container">
    <div class="flex justify-between items-center mb-2">
      <h2>Resources</h2>
      <button class="btn btn-primary hidden" id="res-upload-btn">Upload Resource</button>
    </div>
    <div class="mb-2">
      <select class="form-select" id="res-category-filter" style="max-width:12rem">
        <option value="">All Categories</option>
      </select>
    </div>
    <div class="card-grid" id="resources-grid"></div>
  </div>

  <!-- Upload Modal -->
  <div class="auth-modal hidden" id="res-form-modal">
    <div class="auth-panel" style="max-width:28rem">
      <h3 class="mb-1">Upload Resource</h3>
      <form id="res-form">
        <div class="form-group"><label class="form-label">Title</label><input class="form-input" id="rf-title" required></div>
        <div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="rf-description" rows="2"></textarea></div>
        <div class="form-group"><label class="form-label">Category</label><input class="form-input" id="rf-category" placeholder="e.g. Guides, Templates"></div>
        <div class="form-group">
          <label class="form-label">Type</label>
          <select class="form-select" id="rf-type">
            <option value="pdf">PDF</option>
            <option value="video">Video</option>
            <option value="image">Image</option>
            <option value="link">Link / URL</option>
          </select>
        </div>
        <div class="form-group" id="rf-file-group"><label class="form-label">File</label><input class="form-input" id="rf-file" type="file"></div>
        <div class="form-group hidden" id="rf-url-group"><label class="form-label">URL</label><input class="form-input" id="rf-url" type="url" placeholder="https://..."></div>
        <label class="flex items-center gap-1 mb-2"><input type="checkbox" id="rf-members-only" checked> Members only</label>
        <div class="flex gap-1">
          <button type="submit" class="btn btn-primary">Upload</button>
          <button type="button" class="btn btn-secondary" id="res-form-cancel">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</Portal>

<script>
  import { del, get, post } from '../lib/api';
  import { isAdmin, isAuthenticated } from '../lib/auth';
  import { translateItems } from '../lib/config';

  let allResources: any[] = [];

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = String(s || '');
    return d.innerHTML;
  }

  function fileTypeIcon(type: string): string {
    const icons: Record<string, string> = { pdf: '\u{1F4C4}', video: '\u{1F3AC}', link: '\u{1F517}', image: '\u{1F5BC}\uFE0F' };
    return icons[type] || '\u{1F4C1}';
  }

  function applyFilter() {
    const cat = (document.getElementById('res-category-filter') as HTMLSelectElement)?.value;
    const filtered = cat ? allResources.filter((r) => r.category === cat) : allResources;
    renderResources(filtered);
  }

  function renderResources(resources: any[]) {
    const grid = document.getElementById('resources-grid');
    if (!grid) return;

    // Populate category filter
    const cats = [...new Set(allResources.map((r: any) => r.category).filter(Boolean))];
    const filter = document.getElementById('res-category-filter') as HTMLSelectElement;
    if (filter && filter.children.length <= 1) {
      filter.innerHTML =
        '<option value="">All Categories</option>' +
        cats.map((c) => `<option value="${esc(c as string)}">${esc(c as string)}</option>`).join('');
    }

    if (resources.length === 0) {
      grid.innerHTML = '<p class="text-muted">No resources yet.</p>';
      return;
    }

    grid.innerHTML = resources
      .map((r) => {
        if (r.is_members_only && !isAuthenticated()) return '';
        const icon = fileTypeIcon(r.file_type);
        return `
        <div class="card">
          <div class="flex items-center gap-1 mb-1">
            <span style="font-size:1.5rem">${icon}</span>
            <div>
              <h4 style="margin:0">${esc(r.title)}</h4>
              ${r.category ? `<span class="badge badge-primary">${esc(r.category)}</span>` : ''}
            </div>
          </div>
          ${r.description ? `<p class="text-sm text-muted">${esc(r.description)}</p>` : ''}
          <div class="flex gap-1 mt-1">
            ${r.file_url ? `<a href="${esc(r.file_url)}" class="btn btn-sm btn-secondary" target="_blank">Download</a>` : ''}
            ${r.is_members_only ? '<span class="badge badge-warning">Members Only</span>' : ''}
            ${isAdmin() ? `<button class="btn btn-sm btn-danger res-delete" data-id="${r.id}">Delete</button>` : ''}
          </div>
        </div>`;
      })
      .join('');

    grid.querySelectorAll('.res-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this resource?')) return;
        const id = (btn as HTMLElement).dataset.id!;
        await del(`resources?id=eq.${id}`);
        allResources = allResources.filter((r) => r.id !== parseInt(id, 10));
        renderResources(allResources);
      });
    });
  }

  function setupUpload() {
    const btn = document.getElementById('res-upload-btn');
    if (!btn) return;
    btn.classList.remove('hidden');
    btn.addEventListener('click', () => {
      document.getElementById('res-form-modal')?.classList.remove('hidden');
    });

    document.getElementById('res-form-cancel')?.addEventListener('click', () => {
      document.getElementById('res-form-modal')?.classList.add('hidden');
    });

    document.getElementById('res-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const session = JSON.parse(localStorage.getItem('wl_session') || '{}');

      const fileType = (document.getElementById('rf-type') as HTMLSelectElement).value;
      const data: any = {
        title: (document.getElementById('rf-title') as HTMLInputElement).value,
        description: (document.getElementById('rf-description') as HTMLTextAreaElement).value,
        category: (document.getElementById('rf-category') as HTMLInputElement).value,
        file_type: fileType,
        is_members_only: (document.getElementById('rf-members-only') as HTMLInputElement).checked,
        uploaded_by: session.user?.member?.id,
      };

      if (fileType === 'link') {
        data.file_url = (document.getElementById('rf-url') as HTMLInputElement).value;
        await post('resources', data);
      } else {
        const fileInput = document.getElementById('rf-file') as HTMLInputElement;
        const file = fileInput?.files?.[0];
        if (file) {
          const formData = new FormData();
          formData.append('file', file);
          formData.append('metadata', JSON.stringify(data));
          const res = await fetch(`${window.__KYCHON_API}/functions/v1/upload-resource`, {
            method: 'POST',
            headers: {
              apikey: window.__KYCHON_ANON_KEY,
              Authorization: `Bearer ${session.access_token}`,
            },
            body: formData,
          });
          if (!res.ok) {
            console.error('Upload failed:', await res.text());
            return;
          }
        }
      }

      // Log activity
      const uploaderId = session.user?.member?.id;
      if (uploaderId) {
        await post('activity_log', { member_id: uploaderId, action: 'resource_upload', metadata: { title: data.title } });
      }

      document.getElementById('res-form-modal')?.classList.add('hidden');
      (document.getElementById('res-form') as HTMLFormElement)?.reset();
      allResources = await get('resources?order=created_at.desc');
      renderResources(allResources);
    });
  }

  async function initResources() {
    try {
      allResources = await get('resources?order=created_at.desc');
      await translateItems('resource', allResources, ['title', 'description']);
      renderResources(allResources);
    } catch (e) {
      console.warn('Failed to load resources:', e);
    }

    document.getElementById('res-category-filter')?.addEventListener('change', applyFilter);

    if (isAdmin()) setupUpload();

    // Toggle file/url input based on type
    document.getElementById('rf-type')?.addEventListener('change', (e) => {
      const isLink = (e.target as HTMLSelectElement).value === 'link';
      document.getElementById('rf-file-group')?.classList.toggle('hidden', isLink);
      document.getElementById('rf-url-group')?.classList.toggle('hidden', !isLink);
    });
  }

  initResources();
  document.addEventListener('astro:after-swap', initResources);
  document.addEventListener('wl-locale-changed', initResources);
  document.addEventListener('wl-auth-changed', initResources);
</script>
