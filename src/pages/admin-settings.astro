---
import Portal from '../layouts/Portal.astro';
---
<Portal title="Site Settings">
  <div class="container" style="max-width:48rem">
    <h2 class="mb-2">Site Settings</h2>

    <!-- Branding -->
    <div class="card mb-2">
      <h3 class="mb-1">Branding</h3>
      <form id="as-branding-form">
        <div class="form-group">
          <label class="form-label">Site Name</label>
          <input class="form-input" id="as-site-name">
        </div>
        <div class="form-group">
          <label class="form-label">Tagline</label>
          <input class="form-input" id="as-site-tagline">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea class="form-textarea" id="as-site-description" rows="2"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Logo URL</label>
          <input class="form-input" id="as-logo-url" type="text" placeholder="/assets/logo.png or https://...">
        </div>
        <div class="form-group">
          <label class="form-label">Favicon URL</label>
          <input class="form-input" id="as-favicon-url" type="text" placeholder="/favicon.svg or https://...">
        </div>
        <button type="submit" class="btn btn-primary" id="as-branding-save">Save</button>
      </form>
    </div>

    <!-- Theme -->
    <div class="card mb-2">
      <h3 class="mb-1">Theme</h3>
      <form id="as-theme-form">
        <p class="form-label mb-1">Colors</p>
        <div class="as-color-grid">
          <label class="as-color-swatch" title="Primary">
            <input id="as-primary" type="color">
            <span>Primary</span>
          </label>
          <label class="as-color-swatch" title="Primary Hover">
            <input id="as-primary-hover" type="color">
            <span>Hover</span>
          </label>
          <label class="as-color-swatch" title="Background">
            <input id="as-bg" type="color">
            <span>Background</span>
          </label>
          <label class="as-color-swatch" title="Surface">
            <input id="as-surface" type="color">
            <span>Surface</span>
          </label>
          <label class="as-color-swatch" title="Text">
            <input id="as-text" type="color">
            <span>Text</span>
          </label>
          <label class="as-color-swatch" title="Text Muted">
            <input id="as-text-muted" type="color">
            <span>Muted</span>
          </label>
          <label class="as-color-swatch" title="Border">
            <input id="as-border" type="color">
            <span>Border</span>
          </label>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-top:1rem">
          <div class="form-group">
            <label class="form-label">Border Radius</label>
            <input class="form-input" id="as-radius" placeholder="0.5rem">
          </div>
          <div class="form-group">
            <label class="form-label">Heading Font</label>
            <input class="form-input" id="as-font-heading" placeholder="Inter">
          </div>
          <div class="form-group">
            <label class="form-label">Body Font</label>
            <input class="form-input" id="as-font-body" placeholder="Inter">
          </div>
        </div>
        <button type="submit" class="btn btn-primary" id="as-theme-save">Save</button>
      </form>
    </div>

    <!-- General Settings -->
    <div class="card mb-2">
      <h3 class="mb-1">General</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
        <div class="form-group">
          <label class="form-label">Signup Mode</label>
          <select class="form-select" id="as-signup-mode">
            <option value="open">Open (anyone can join)</option>
            <option value="approved">Approved (admin approves)</option>
            <option value="closed">Closed (invite only)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Default Language</label>
          <select class="form-select" id="as-default-language">
            <option value="en">English</option>
            <option value="es">Spanish</option>
          </select>
        </div>
      </div>
      <div class="mt-1">
        <label class="flex items-center gap-1" style="padding:0.375rem 0">
          <input type="checkbox" id="as-directory-public">
          <span>Member directory visible to visitors</span>
        </label>
        <label class="flex items-center gap-1" style="padding:0.375rem 0">
          <input type="checkbox" id="as-polls-member-create">
          <span>Members can create polls</span>
        </label>
      </div>
      <button class="btn btn-primary mt-1" id="as-general-save">Save</button>
    </div>

    <!-- Feature Flags -->
    <div class="card mb-2">
      <h3 class="mb-1">Features</h3>
      <div id="as-features"></div>
    </div>

    <!-- Tiers -->
    <div class="card mb-2">
      <h3 class="mb-1">Membership Tiers</h3>
      <div id="as-tiers"></div>
    </div>

    <!-- Custom Fields -->
    <div class="card mb-2">
      <h3 class="mb-1">Member Custom Fields</h3>
      <p class="text-sm text-muted mb-1">Fields shown on member profiles and (optionally) in the directory.</p>
      <div id="as-custom-fields"></div>
    </div>

    <!-- AI Features -->
    <div class="card mb-2">
      <h3 class="mb-1">AI Features</h3>
      <p class="text-sm text-muted mb-2">Platform-native AI moderation and translation. No API key required.</p>
      <div id="as-ai-toggles"></div>
      <div class="mt-2" id="as-ai-activity"></div>
    </div>
  </div>

  <style>
    .as-color-grid {
      display: flex; flex-wrap: wrap; gap: 1rem;
    }
    .as-color-swatch {
      display: flex; flex-direction: column; align-items: center; gap: 0.25rem; cursor: pointer;
    }
    .as-color-swatch input[type="color"] {
      -webkit-appearance: none; appearance: none;
      width: 48px; height: 48px; border-radius: 50%; border: 3px solid var(--color-border, #e2e8f0);
      padding: 0; cursor: pointer; overflow: hidden; background: none;
    }
    .as-color-swatch input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
    .as-color-swatch input[type="color"]::-webkit-color-swatch { border: none; border-radius: 50%; }
    .as-color-swatch input[type="color"]::-moz-color-swatch { border: none; border-radius: 50%; }
    .as-color-swatch input[type="color"]:hover { border-color: var(--color-primary, #3b82f6); transform: scale(1.1); }
    .as-color-swatch input[type="color"]:focus { outline: 2px solid var(--color-primary, #3b82f6); outline-offset: 2px; }
    .as-color-swatch span { font-size: 0.7rem; color: var(--color-text-muted, #94a3b8); }
  </style>
</Portal>

<script>
  import { del, get, patch, post } from '../lib/api';
  import { requireAdmin } from '../lib/auth';
  import { ready, applyTheme, clearCache } from '../lib/config';

  const configMap: Record<string, any> = {};

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = String(s || '');
    return d.innerHTML;
  }

  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement)?.value || '';
  }

  function setVal(id: string, val: any) {
    const el = document.getElementById(id) as HTMLInputElement;
    if (el) el.value = val || '';
  }

  function showSaved(id: string) {
    const btn = document.getElementById(id);
    if (!btn) return;
    btn.textContent = 'Saved!';
    setTimeout(() => (btn.textContent = 'Save'), 2000);
  }

  async function patchConfig(key: string, value: any) {
    await patch(`site_config?key=eq.${key}`, { value });
  }

  async function saveBranding(e: Event) {
    e.preventDefault();
    await Promise.all([
      patchConfig('site_name', getVal('as-site-name')),
      patchConfig('site_tagline', getVal('as-site-tagline')),
      patchConfig('site_description', getVal('as-site-description')),
      patchConfig('logo_url', getVal('as-logo-url')),
      patchConfig('favicon_url', getVal('as-favicon-url')),
    ]);
    showSaved('as-branding-save');
  }

  async function saveTheme(e: Event) {
    e.preventDefault();
    const theme = {
      primary: getVal('as-primary'),
      primary_hover: getVal('as-primary-hover'),
      bg: getVal('as-bg'),
      surface: getVal('as-surface'),
      text: getVal('as-text'),
      text_muted: getVal('as-text-muted'),
      border: getVal('as-border'),
      font_heading: getVal('as-font-heading'),
      font_body: getVal('as-font-body'),
      radius: getVal('as-radius'),
    };
    await patchConfig('theme', theme);
    applyTheme(theme);
    clearCache('wl_cache_site_config');
    showSaved('as-theme-save');
  }

  let allTiers: any[] = [];

  async function loadTiers() {
    const container = document.getElementById('as-tiers');
    if (!container) return;
    try {
      allTiers = await get('membership_tiers?order=position.asc');
      renderTiers(container);
    } catch {}
  }

  function renderTiers(container: HTMLElement) {
    container.innerHTML = allTiers
      .map(
        (t: any) => `
      <div class="card mb-1 flex justify-between items-center" style="padding:0.75rem 1rem;cursor:pointer" data-tier-id="${t.id}">
        <div>
          <strong>${esc(t.name)}</strong>
          ${t.is_default ? '<span class="badge badge-primary">Default</span>' : ''}
          <div class="text-sm text-muted">${esc(t.price_label || 'Free')} — ${(t.benefits || []).join(', ')}</div>
        </div>
        <span class="text-muted" style="font-size:0.8rem">Click to edit</span>
      </div>`,
      )
      .join('') + '<button class="btn btn-secondary btn-sm mt-1" id="as-tier-add">+ Add Tier</button>';

    // Bind click to edit
    container.querySelectorAll('[data-tier-id]').forEach((card) => {
      card.addEventListener('click', () => {
        const id = parseInt((card as HTMLElement).dataset.tierId!);
        const tier = allTiers.find((t: any) => t.id === id);
        if (tier) openTierEditor(tier, container);
      });
    });

    // Add tier
    container.querySelector('#as-tier-add')?.addEventListener('click', async () => {
      try {
        const [created] = await post('membership_tiers', {
          name: 'New Tier',
          price_label: 'Free',
          benefits: [],
          position: allTiers.length + 1,
          is_default: false,
        });
        allTiers.push(created);
        renderTiers(container);
        openTierEditor(created, container);
      } catch (e) {
        console.error('Failed to create tier:', e);
      }
    });
  }

  function openTierEditor(tier: any, container: HTMLElement) {
    // Remove existing popover
    document.querySelector('.admin-popover-backdrop')?.remove();
    document.querySelector('.admin-popover')?.remove();

    const benefits = (tier.benefits || []).slice();

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';

    const popover = document.createElement('div');
    popover.className = 'admin-popover';
    popover.innerHTML = `
      <h3>Edit Tier</h3>
      <div class="form-group"><label class="form-label">Name</label><input class="form-input" id="te-name" value="${esc(tier.name || '')}"></div>
      <div class="form-group"><label class="form-label">Price Label</label><input class="form-input" id="te-price" value="${esc(tier.price_label || '')}" placeholder="Free, $10/mo, etc."></div>
      <div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="te-desc" rows="2">${esc(tier.description || '')}</textarea></div>
      <div class="form-group">
        <label class="form-label">Benefits</label>
        <div id="te-benefits"></div>
        <button class="btn btn-sm btn-secondary mt-1" id="te-add-benefit">+ Add benefit</button>
      </div>
      <label class="flex items-center gap-1 mt-1"><input type="checkbox" id="te-default" ${tier.is_default ? 'checked' : ''}> Default tier</label>
      <div class="popover-actions">
        <button class="btn btn-sm btn-danger" id="te-delete">Delete</button>
        <div style="flex:1"></div>
        <button class="btn btn-sm btn-secondary" id="te-cancel">Cancel</button>
        <button class="btn btn-sm btn-primary" id="te-save">Save</button>
      </div>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(popover);

    function renderBenefits() {
      const bc = popover.querySelector('#te-benefits')!;
      bc.innerHTML = benefits.map((b: string, i: number) =>
        `<div class="flex gap-1 mb-1" style="align-items:center"><input class="form-input" value="${esc(b)}" data-bi="${i}" style="flex:1"><button class="btn btn-sm btn-danger" data-remove="${i}" style="padding:0.25rem 0.5rem">&times;</button></div>`
      ).join('');
      bc.querySelectorAll('input').forEach((inp) => {
        inp.addEventListener('change', () => {
          benefits[parseInt((inp as HTMLElement).dataset.bi!)] = (inp as HTMLInputElement).value;
        });
      });
      bc.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.addEventListener('click', () => {
          benefits.splice(parseInt((btn as HTMLElement).dataset.remove!), 1);
          renderBenefits();
        });
      });
    }
    renderBenefits();

    popover.querySelector('#te-add-benefit')?.addEventListener('click', () => {
      benefits.push('');
      renderBenefits();
      const inputs = popover.querySelectorAll('#te-benefits input');
      (inputs[inputs.length - 1] as HTMLInputElement)?.focus();
    });

    popover.querySelector('#te-save')?.addEventListener('click', async () => {
      try {
        await patch(`membership_tiers?id=eq.${tier.id}`, {
          name: (popover.querySelector('#te-name') as HTMLInputElement).value,
          price_label: (popover.querySelector('#te-price') as HTMLInputElement).value,
          description: (popover.querySelector('#te-desc') as HTMLTextAreaElement).value,
          benefits,
          is_default: (popover.querySelector('#te-default') as HTMLInputElement).checked,
        });
        close();
        allTiers = await get('membership_tiers?order=position.asc');
        renderTiers(container);
      } catch (e) { console.error('Tier save failed:', e); }
    });

    popover.querySelector('#te-delete')?.addEventListener('click', async () => {
      if (!confirm(`Delete tier "${tier.name}"?`)) return;
      try {
        await del(`membership_tiers?id=eq.${tier.id}`);
        close();
        allTiers = await get('membership_tiers?order=position.asc');
        renderTiers(container);
      } catch (e) { console.error('Tier delete failed:', e); }
    });

    popover.querySelector('#te-cancel')?.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    function close() {
      popover.remove();
      backdrop.remove();
    }
  }

  // --- Custom fields editor ---
  let allFields: any[] = [];

  async function loadCustomFields() {
    const container = document.getElementById('as-custom-fields');
    if (!container) return;
    try {
      allFields = await get('member_custom_fields?order=position.asc');
      renderFields(container);
    } catch {}
  }

  function renderFields(container: HTMLElement) {
    container.innerHTML = (allFields.length === 0
      ? '<p class="text-muted mb-1">No custom fields defined.</p>'
      : allFields.map((f: any) => `
        <div class="card mb-1 flex justify-between items-center" style="padding:0.5rem 0.75rem;cursor:pointer" data-field-id="${f.id}">
          <div>
            <strong>${esc(f.field_label)}</strong>
            <span class="badge badge-primary" style="margin-left:0.5rem">${esc(f.field_type)}</span>
            ${f.required ? '<span class="badge badge-warning">Required</span>' : ''}
            ${f.visible_in_directory ? '<span class="badge badge-secondary">In directory</span>' : ''}
          </div>
          <span class="text-muted" style="font-size:0.8rem">Edit</span>
        </div>`).join(''))
      + '<button class="btn btn-secondary btn-sm mt-1" id="as-field-add">+ Add Field</button>';

    container.querySelectorAll('[data-field-id]').forEach((card) => {
      card.addEventListener('click', () => {
        const id = parseInt((card as HTMLElement).dataset.fieldId!);
        const field = allFields.find((f: any) => f.id === id);
        if (field) openFieldEditor(field, container);
      });
    });

    container.querySelector('#as-field-add')?.addEventListener('click', async () => {
      try {
        const [created] = await post('member_custom_fields', {
          field_name: 'new_field',
          field_label: 'New Field',
          field_type: 'text',
          required: false,
          visible_in_directory: false,
          position: allFields.length + 1,
        });
        allFields.push(created);
        renderFields(container);
        openFieldEditor(created, container);
      } catch (e) { console.error('Failed to create field:', e); }
    });
  }

  function openFieldEditor(field: any, container: HTMLElement) {
    document.querySelector('.admin-popover-backdrop')?.remove();
    document.querySelector('.admin-popover')?.remove();

    const backdrop = document.createElement('div');
    backdrop.className = 'admin-popover-backdrop';

    const popover = document.createElement('div');
    popover.className = 'admin-popover';
    popover.innerHTML = `
      <h3>Edit Custom Field</h3>
      <div class="form-group"><label class="form-label">Label</label><input class="form-input" id="fe-label" value="${esc(field.field_label || '')}"></div>
      <div class="form-group"><label class="form-label">Field Name (slug)</label><input class="form-input" id="fe-name" value="${esc(field.field_name || '')}" placeholder="e.g. phone_number"></div>
      <div class="form-group">
        <label class="form-label">Type</label>
        <select class="form-select" id="fe-type">
          <option value="text"${field.field_type === 'text' ? ' selected' : ''}>Text</option>
          <option value="textarea"${field.field_type === 'textarea' ? ' selected' : ''}>Textarea</option>
          <option value="select"${field.field_type === 'select' ? ' selected' : ''}>Select (dropdown)</option>
          <option value="checkbox"${field.field_type === 'checkbox' ? ' selected' : ''}>Checkbox</option>
        </select>
      </div>
      <div class="form-group" id="fe-options-group" style="${field.field_type === 'select' ? '' : 'display:none'}">
        <label class="form-label">Options (one per line)</label>
        <textarea class="form-textarea" id="fe-options" rows="3">${field.options ? (Array.isArray(field.options) ? field.options.join('\n') : '') : ''}</textarea>
      </div>
      <label class="flex items-center gap-1 mt-1"><input type="checkbox" id="fe-required" ${field.required ? 'checked' : ''}> Required</label>
      <label class="flex items-center gap-1"><input type="checkbox" id="fe-directory" ${field.visible_in_directory ? 'checked' : ''}> Show in member directory</label>
      <div class="popover-actions">
        <button class="btn btn-sm btn-danger" id="fe-delete">Delete</button>
        <div style="flex:1"></div>
        <button class="btn btn-sm btn-secondary" id="fe-cancel">Cancel</button>
        <button class="btn btn-sm btn-primary" id="fe-save">Save</button>
      </div>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(popover);

    // Show/hide options based on type
    popover.querySelector('#fe-type')?.addEventListener('change', () => {
      const isSelect = (popover.querySelector('#fe-type') as HTMLSelectElement).value === 'select';
      (popover.querySelector('#fe-options-group') as HTMLElement).style.display = isSelect ? '' : 'none';
    });

    popover.querySelector('#fe-save')?.addEventListener('click', async () => {
      const fieldType = (popover.querySelector('#fe-type') as HTMLSelectElement).value;
      const optionsText = (popover.querySelector('#fe-options') as HTMLTextAreaElement).value;
      const options = fieldType === 'select' ? optionsText.split('\n').map((o: string) => o.trim()).filter(Boolean) : null;
      try {
        await patch(`member_custom_fields?id=eq.${field.id}`, {
          field_label: (popover.querySelector('#fe-label') as HTMLInputElement).value,
          field_name: (popover.querySelector('#fe-name') as HTMLInputElement).value,
          field_type: fieldType,
          options,
          required: (popover.querySelector('#fe-required') as HTMLInputElement).checked,
          visible_in_directory: (popover.querySelector('#fe-directory') as HTMLInputElement).checked,
        });
        close();
        allFields = await get('member_custom_fields?order=position.asc');
        renderFields(container);
      } catch (e) { console.error('Field save failed:', e); }
    });

    popover.querySelector('#fe-delete')?.addEventListener('click', async () => {
      if (!confirm(`Delete field "${field.field_label}"?`)) return;
      try {
        await del(`member_custom_fields?id=eq.${field.id}`);
        close();
        allFields = await get('member_custom_fields?order=position.asc');
        renderFields(container);
      } catch (e) { console.error('Field delete failed:', e); }
    });

    popover.querySelector('#fe-cancel')?.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    function close() { popover.remove(); backdrop.remove(); }
  }

  function setupAISettings() {
    const toggleContainer = document.getElementById('as-ai-toggles');
    if (toggleContainer) {
      const aiFlags = ['feature_ai_moderation', 'feature_ai_translation'];
      toggleContainer.innerHTML = aiFlags
        .map((key) => {
          const val = configMap[key];
          const checked = val === true || val === 'true';
          const label = key.replace('feature_ai_', '').replace(/_/g, ' ');
          return `<label class="flex items-center gap-1" style="padding:0.375rem 0">
          <input type="checkbox" class="ai-toggle" data-key="${key}" ${checked ? 'checked' : ''}>
          <span>AI ${label}</span>
        </label>`;
        })
        .join('');

      toggleContainer.querySelectorAll('.ai-toggle').forEach((cb) => {
        cb.addEventListener('change', async () => {
          const el = cb as HTMLInputElement;
          await patchConfig(el.dataset.key!, el.checked);
        });
      });
    }

    loadAIActivity();
  }

  async function loadAIActivity() {
    const container = document.getElementById('as-ai-activity');
    if (!container) return;

    try {
      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
      const since = sevenDaysAgo.toISOString();

      const [modCount, transCount] = await Promise.all([
        get(`moderation_log?created_at=gte.${since}&select=id`)
          .then((r: any[]) => r.length)
          .catch(() => 0),
        get(`content_translations?created_at=gte.${since}&select=id`)
          .then((r: any[]) => r.length)
          .catch(() => 0),
      ]);

      if (modCount || transCount) {
        container.innerHTML = `
          <h4 class="mb-1">AI Activity (last 7 days)</h4>
          <div class="text-sm text-muted">
            ${modCount ? `<div>${modCount} posts moderated</div>` : ''}
            ${transCount ? `<div>${transCount} translations created</div>` : ''}
          </div>`;
      }
    } catch {}
  }

  async function initAdminSettings() {
    await ready;
    if (!requireAdmin()) return;

    // Load current config
    try {
      const rows = await get('site_config');
      for (const row of rows) configMap[row.key] = row.value;
    } catch {}

    // Populate branding
    setVal('as-site-name', configMap.site_name);
    setVal('as-site-tagline', configMap.site_tagline);
    setVal('as-site-description', configMap.site_description);
    setVal('as-logo-url', configMap.logo_url);
    setVal('as-favicon-url', configMap.favicon_url);

    // Populate theme
    const theme = configMap.theme || {};
    setVal('as-primary', theme.primary);
    setVal('as-primary-hover', theme.primary_hover);
    setVal('as-bg', theme.bg);
    setVal('as-surface', theme.surface);
    setVal('as-text', theme.text);
    setVal('as-text-muted', theme.text_muted);
    setVal('as-border', theme.border);
    setVal('as-font-heading', theme.font_heading);
    setVal('as-font-body', theme.font_body);
    setVal('as-radius', theme.radius);

    // Populate general settings
    setVal('as-signup-mode', configMap.signup_mode || 'approved');
    setVal('as-default-language', configMap.default_language || 'en');
    (document.getElementById('as-directory-public') as HTMLInputElement).checked = configMap.directory_public === true;
    (document.getElementById('as-polls-member-create') as HTMLInputElement).checked = configMap.polls_member_create === true;

    // Populate feature flags
    const featureContainer = document.getElementById('as-features');
    if (featureContainer) {
      const flags = Object.entries(configMap)
        .filter(([k]) => k.startsWith('feature_'))
        .sort(([a], [b]) => a.localeCompare(b));
      featureContainer.innerHTML = flags
        .map(
          ([key, val]) => `
        <label class="flex items-center gap-1" style="padding:0.5rem 0">
          <input type="checkbox" class="feature-toggle" data-key="${key}" ${val === true || val === 'true' ? 'checked' : ''}>
          <span>${key.replace('feature_', '').replace(/_/g, ' ')}</span>
        </label>`,
        )
        .join('');
    }

    await loadTiers();
    await loadCustomFields();
    setupAISettings();

    // Save handlers
    document.getElementById('as-branding-form')?.addEventListener('submit', saveBranding);
    document.getElementById('as-theme-form')?.addEventListener('submit', saveTheme);
    document.getElementById('as-general-save')?.addEventListener('click', async () => {
      await Promise.all([
        patchConfig('signup_mode', getVal('as-signup-mode')),
        patchConfig('default_language', getVal('as-default-language')),
        patchConfig('directory_public', (document.getElementById('as-directory-public') as HTMLInputElement).checked),
        patchConfig('polls_member_create', (document.getElementById('as-polls-member-create') as HTMLInputElement).checked),
      ]);
      showSaved('as-general-save');
    });

    // Feature flag toggles
    document.querySelectorAll('.feature-toggle').forEach((cb) => {
      cb.addEventListener('change', async () => {
        const el = cb as HTMLInputElement;
        await patchConfig(el.dataset.key!, el.checked);
      });
    });
  }

  initAdminSettings();
  document.addEventListener('astro:after-swap', initAdminSettings);
  document.addEventListener('wl-locale-changed', initAdminSettings);
  document.addEventListener('wl-auth-changed', initAdminSettings);
</script>
