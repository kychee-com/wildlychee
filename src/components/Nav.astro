---
// Nav.astro — Static HTML shell for navigation, populated at runtime by ConfigProvider
---
<nav class="nav" aria-label="Primary navigation" transition:persist>
  <div class="container">
    <a href="/" class="nav-brand">
      <img src="" alt="" style="display:none">
      <span class="nav-brand-text">Kychon</span>
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menu">&#9776;</button>
    <div class="nav-links" id="nav-links"></div>
    <button class="admin-nav-edit-btn" id="admin-nav-edit-btn" title="Edit navigation" style="display:none">&#9998;</button>
    <div class="nav-user" id="nav-user"></div>
  </div>
</nav>
