---
// AuthModal.astro — Sign in / sign up modal
---
<div class="auth-modal hidden" id="auth-modal">
  <div class="auth-panel">
    <h2 id="auth-title">Sign In</h2>
    <div id="auth-error" class="text-sm hidden" style="color:var(--color-danger);margin-bottom:1rem"></div>

    <button class="btn-google" id="google-btn">
      <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.997 8.997 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/></svg>
      Sign in with Google
    </button>

    <div class="auth-divider">or</div>

    <form id="auth-form">
      <div class="form-group">
        <label class="form-label" for="auth-email">Email</label>
        <input class="form-input" type="email" id="auth-email" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="auth-password">Password</label>
        <input class="form-input" type="password" id="auth-password" required minlength="6">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%" id="auth-submit-btn">Sign In</button>
    </form>

    <p class="text-sm text-muted mt-2 text-center">
      <a href="#" id="auth-toggle">Don't have an account? Sign up</a>
    </p>
    <p class="text-sm text-muted mt-1 text-center">
      <a href="#" id="auth-close">Close</a>
    </p>
  </div>
</div>

<script>
  import { signInWithGoogle, signIn, signUp } from '../lib/auth';

  let isSignUp = false;

  function setupAuthModal() {
    document.getElementById('google-btn')?.addEventListener('click', () => signInWithGoogle());

    document.getElementById('auth-toggle')?.addEventListener('click', (e) => {
      e.preventDefault();
      isSignUp = !isSignUp;
      const title = document.getElementById('auth-title');
      const toggle = document.getElementById('auth-toggle');
      const submitBtn = document.getElementById('auth-submit-btn');
      if (title) title.textContent = isSignUp ? 'Sign Up' : 'Sign In';
      if (toggle) toggle.textContent = isSignUp ? 'Already have an account? Sign in' : "Don't have an account? Sign up";
      if (submitBtn) submitBtn.textContent = isSignUp ? 'Sign Up' : 'Sign In';
    });

    document.getElementById('auth-close')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('auth-modal')?.classList.add('hidden');
    });

    document.getElementById('auth-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('auth-email') as HTMLInputElement).value;
      const password = (document.getElementById('auth-password') as HTMLInputElement).value;
      const errorEl = document.getElementById('auth-error');

      try {
        if (isSignUp) {
          await signUp(email, password);
          if (errorEl) {
            errorEl.textContent = 'Account created! Please check your email to verify.';
            errorEl.style.color = 'var(--color-success)';
            errorEl.classList.remove('hidden');
          }
        } else {
          await signIn(email, password);
          document.getElementById('auth-modal')?.classList.add('hidden');
          // Re-init config (loads member record, rebuilds nav with auth state)
          const { init } = await import('../lib/config');
          await init();
          // Re-render current page content
          document.dispatchEvent(new CustomEvent('wl-auth-changed'));
        }
      } catch (err: any) {
        if (errorEl) {
          errorEl.textContent = err.message || 'Authentication failed';
          errorEl.style.color = 'var(--color-danger)';
          errorEl.classList.remove('hidden');
        }
      }
    });
  }

  setupAuthModal();
  document.addEventListener('astro:after-swap', setupAuthModal);
</script>
