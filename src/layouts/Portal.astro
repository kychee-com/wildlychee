---
// Portal.astro — Main layout wrapping all portal pages
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ConfigProvider from '../components/ConfigProvider.astro';
import AuthProvider from '../components/AuthProvider.astro';
import AuthModal from '../components/AuthModal.astro';
import Toast from '../components/Toast.astro';
import AdminEditor from '../components/AdminEditor.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/a11y.css">
  <ClientRouter />
  <script is:inline>
    (()=> {var t=localStorage.getItem('wl_theme');if(!t)t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';if(t==='dark')document.documentElement.setAttribute('data-theme','dark')})()
  </script>
  <script is:inline src="/js/env.js"></script>
</head>
<body>
  <a href="#main-content" class="wl-skip-nav">Skip to main content</a>
  <div class="page">
    <Nav />

    <main class="page-content" id="main-content">
      <slot />
    </main>

    <Footer />
    <AuthModal />
  </div>

  <AuthProvider />
  <ConfigProvider />
  <Toast />
  <AdminEditor />

  <div id="wl-sr-live" class="wl-sr-live" aria-live="polite" aria-atomic="true"></div>
</body>
</html>
