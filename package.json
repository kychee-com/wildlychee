{
  "name": "wildlychee",
  "version": "0.1.0",
  "description": "AI-powered membership/community portal template for Run402",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "node deploy.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "vitest run && biome check . && tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kychee-com/wildlychee.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^3.1.1",
    "fast-check": "^4.1.1",
    "happy-dom": "^17.4.4",
    "typescript": "^6.0.2",
    "vitest": "^3.1.1"
  }
}
